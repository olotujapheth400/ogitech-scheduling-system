<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>OGITECH Admin - Terminal Authentication</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #111; color: #fff; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-box { background: #222; padding: 30px; border-radius: 8px; border: 1px solid #333; width: 100%; max-width: 400px; box-sizing: border-box; }
        h2 { color: #3498db; text-align: center; margin-top: 0; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        label { font-weight: bold; display: block; margin-top: 15px; color: #bdc3c7; }
        input { padding: 12px; margin: 8px 0; width: 100%; box-sizing: border-box; border: 1px solid #444; border-radius: 4px; background: #333; color: #fff; font-size: 14px; }
        button { background-color: #3498db; color: white; border: none; padding: 12px; width: 100%; border-radius: 4px; font-weight: bold; cursor: pointer; margin-top: 15px; font-size: 14px; }
        button:hover { background-color: #2980b9; }
        .error-banner { background: #441a1a; color: #ff9999; border-left: 5px solid #e74c3c; padding: 12px; margin-bottom: 15px; border-radius: 4px; font-size: 14px; text-align: center; }
    </style>
</head>
<body>

<div class="login-box">
    <h2>📊 OGITECH Executive Administration</h2>
    
    <% if (locals.error || (locals.query && query.error === 'true')) { %>
        <div class="error-banner">⚠️ Unauthorized Administrative Access</div>
    <% } %>

    <form action="/ogitech-boardroom-vault-2026" method="POST">
        <label>System Administrator ID:</label>
        <input type="text" name="username" placeholder="Enter admin username" required autocomplete="off">

        <label>Administrative Security Passkey:</label>
        <input type="password" name="password" placeholder="Enter admin password" required>

        <button type="submit">Unlock Admin Panel</button>
    </form>
</div>

</body>
</html>