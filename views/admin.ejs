<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>OGITECH Restaurant - Executive Administration Dashboard</title>
    
    <!-- Premium Dynamic Browser Tab Favicon Icon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%233498db'%3E%3Cpath d='M11 2v20H9v-2H7v-2H5v-2H3v-2H1v-2h22v2h-2v2h-2v2h-2v2h-2V2h-2zm2 5h4v2h-4zm0 4h4v2h-4zm-8 4h14v2H5zm0 4h14v2H5z'/%3E%3Cpolygon points='12,2 10,5 14,5' fill='%23d4af37'/%3E%3C/svg%3E">

    <!-- High-End Typography Import -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-master: #0a0a0c;
            --bg-surface: #141419;
            --bg-surface-elevated: #1d1d26;
            --accent-blue: #3498db;
            --accent-blue-hover: #2980b9;
            --accent-orange: #e67e22;
            --accent-purple: #9b59b6;
            --accent-green: #2ecc71;
            --accent-red: #e74c3c;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border-glow: #2a2a35;
            --shadow-premium: 0 20px 40px rgba(0,0,0,0.6);
        }

        body { 
            font-family: 'Poppins', sans-serif; 
            margin: 0; 
            padding: 40px 20px;
            background-color: var(--bg-master); 
            color: var(--text-main); 
        }

        .main-wrapper { 
            display: flex; 
            gap: 25px; 
            max-width: 1300px; 
            margin: 0 auto; 
            flex-wrap: wrap;
        }

        .container { 
            flex: 3; 
            min-width: 350px;
            background: var(--bg-surface); 
            padding: 35px; 
            border-radius: 16px; 
            border: 1px solid var(--border-glow); 
            height: fit-content; 
            box-shadow: var(--shadow-premium);
        }

        .sidebar { 
            flex: 1; 
            min-width: 280px;
            background: var(--bg-surface); 
            padding: 25px; 
            border-radius: 16px; 
            border: 1px solid var(--border-glow); 
            height: fit-content; 
            display: flex; 
            flex-direction: column; 
            gap: 25px; 
            min-height: 450px;
            box-shadow: var(--shadow-premium);
        }

        h2 { 
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            color: var(--accent-blue); 
            border-bottom: 2px solid var(--accent-blue); 
            padding-bottom: 15px; 
            text-align: center; 
            margin-top: 0; 
            margin-bottom: 30px;
            letter-spacing: -0.5px;
        }

        h3 { 
            color: #5dade2; 
            margin-top: 40px; 
            margin-bottom: 20px;
            border-left: 4px solid #5dade2; 
            padding-left: 12px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            font-size: 1.15rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 30px; }
        th, td { border: 1px solid var(--border-glow); padding: 14px 12px; text-align: left; font-size: 13px; }
        th { background-color: var(--bg-master); color: var(--accent-blue); font-weight: 600; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
        tr:nth-child(even) { background-color: rgba(255, 255, 255, 0.01); }
        
        .btn-algo { 
            padding: 12px 20px; 
            background: linear-gradient(135deg, var(--accent-orange), #d35400); 
            border: none; 
            color: white; 
            font-weight: 600; 
            border-radius: 8px; 
            cursor: pointer; 
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: transform 0.2s, opacity 0.2s;
        }
        .btn-algo:hover { transform: translateY(-1px); opacity: 0.95; }

        .select-algo, .input-override { 
            padding: 12px; 
            background: var(--bg-master); 
            color: #fff; 
            border: 1px solid var(--border-glow); 
            border-radius: 8px; 
            width: 100%; 
            margin-top: 5px; 
            font-family: 'Poppins', sans-serif;
            box-sizing: border-box;
        }
        .select-algo:focus, .input-override:focus { border-color: var(--accent-blue); outline: none; }

        .badge-vip { background: var(--accent-purple); color: white; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge-std { background: #7f8c8d; color: white; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        
        .logout-btn { 
            padding: 14px 15px; 
            background: linear-gradient(135deg, var(--accent-red), #c0392b); 
            color: white; 
            text-decoration: none; 
            border-radius: 8px; 
            font-weight: 600; 
            text-align: center; 
            font-size: 14px; 
            transition: all 0.3s ease; 
            border: none; 
            margin-top: auto; 
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 12px rgba(231, 76, 60, 0.2);
        }
        .logout-btn:hover { opacity: 0.9; transform: translateY(-1px); }

        .stat-count-badge { color: #fff; font-size: 11px; padding: 4px 12px; border-radius: 20px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .orange-badge { background: #d35400; }
        .green-badge { background: var(--accent-green); }
        .purple-badge { background: var(--accent-purple); }
        
        .view-all-link { color: var(--accent-blue); text-decoration: none; font-size: 13px; font-weight: 600; }
        .view-all-link:hover { text-decoration: underline; }

        .btn-force-push {
            padding: 6px 12px;
            background: linear-gradient(135deg, var(--accent-green), #27ae60);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 4px;
            cursor: pointer;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-force-push:hover { opacity: 0.9; }

        .btn-delete {
            padding: 6px 12px;
            background: linear-gradient(135deg, var(--accent-red), #c0392b);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 4px;
            cursor: pointer;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-delete:hover { opacity: 0.9; }
    </style>
</head>
<body>

<div class="main-wrapper">
    <div class="container">
        <h2>📊 OGITECH Restaurant - Executive Administration Controls</h2>
        
        <!-- MODULE 1: SCHEDULING DISPATCH FRAMEWORK CONTROLLER -->
        <div style="background: rgba(52, 152, 219, 0.03); padding: 20px; border-radius: 12px; margin-bottom: 25px; border: 1px dashed var(--accent-blue);">
            <h3 style="font-size:15px; color:var(--accent-orange); border-left-color:var(--accent-orange); margin-top:0; margin-bottom:12px;">⚙ Toggle Core Scheduling Logic Algorithm</h3>
            <form action="/change-algo" method="POST" style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight:500;">Select Algorithm Framework Model:</label>
                    <select name="algorithm" class="select-algo">
                        <option value="sjf" <%= locals.algo === 'sjf' ? 'selected' : '' %>>Shortest Job First (SJF Mode)</option>
                        <option value="fifo" <%= locals.algo === 'fifo' ? 'selected' : '' %>>First-In, First-Out (FIFO Mode)</option>
                    </select>
                </div>
                <button type="submit" class="btn-algo" style="margin-top: 22px;">Enforce Logic Re-Sort</button>
            </form>
        </div>

        <!-- MODULE 2: LIVE WEBHOOK BYPASS VAULT -->
        <div style="background: rgba(155, 89, 182, 0.03); padding: 20px; border-radius: 12px; margin-bottom: 25px; border: 1px dashed var(--accent-purple);">
            <h3 style="font-size:15px; color:var(--accent-purple); border-left-color:var(--accent-purple); margin-top:0; margin-bottom:12px;">⚡ Live Webhook Bypass Vault (Manual Override Console)</h3>
            <p style="margin: 0 0 15px 0; font-size:12.5px; color:var(--text-muted); line-height:1.5;">
                In the event of a localized customer network drop where a payment is debited but the webhook fails to sync, use this panel to manually authorize or clear stale records to maintain a clean production ledger.
            </p>
            
            <!-- Quick Manual Override Entry Form Box -->
            <form action="/admin/force-approve" method="POST" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 20px; background: var(--bg-master); padding: 15px; border-radius: 8px; border: 1px solid var(--border-glow);">
                <div style="flex: 2; min-width: 240px;">
                    <label style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Manually Force Approve by Any Order ID Code:</label>
                    <input type="text" name="orderId" class="input-override" placeholder="e.g., OGI-X8W2" required>
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <button type="submit" class="btn-algo" style="background: linear-gradient(135deg, var(--accent-purple), #8e44ad); width: 100%;">Push To Kitchen</button>
                </div>
            </form>

            <!-- Inline Pending Approval Queue Matrix Loop -->
            <label style="font-size: 11px; color: var(--text-muted); text-transform: uppercase; font-weight: 600; display: block; margin-bottom: 8px;">Inbound Unverified Transactions Pool:</label>
            <table style="margin-bottom:0; margin-top:0;">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Meal Selected</th>
                        <th>Bill Amount</th>
                        <th>Demo Override Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (locals.unverifiedOrders && unverifiedOrders.length > 0) { %>
                        <% unverifiedOrders.forEach(order => { %>
                            <tr>
                                <td><code style="color:var(--accent-orange);"><%= order.orderId %></code></td>
                                <td><%= order.customerName %></td>
                                <td><%= order.quantity || 1 %>x <%= order.foodName %></td>
                                <td style="color:var(--accent-green);">₦<%= (order.totalPrice || 0).toLocaleString() %></td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <form action="/admin/force-approve" method="POST" style="margin:0;">
                                            <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                            <button type="submit" class="btn-force-push">⚡ Approve</button>
                                        </form>
                                        <form action="/admin/delete-order" method="POST" style="margin:0;" onsubmit="return confirm('Are you sure you want to delete this pending transaction?');">
                                            <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                            <button type="submit" class="btn-delete">🗑 Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align:center; color:#555; padding:12px; font-size:12.5px;">No unverified standalone orders currently parked in the memory banks.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- MODULE 3: ACTIVE KITCHEN DISPATCH SCHEDULING MONITOR -->
        <h3 style="margin-top: 35px;">
            <span>🍳 Active Kitchen Workload Queue</span>
            <span class="stat-count-badge orange-badge"><%= locals.jobs ? jobs.length : 0 %> Pending Orders</span>
        </h3>
        <table>
            <thead>
                <tr>
                    <th>Sequence Rank</th>
                    <th>Order ID</th>
                    <th>Inbound Time</th>
                    <th>Customer Name</th>
                    <th>Food Item & Volume Requested</th>
                    <th>Processing Cost</th>
                </tr>
            </thead>
            <tbody>
                <% if (!locals.jobs || jobs.length === 0) { %>
                    <tr><td colspan="6" style="text-align:center; color: #777; padding: 20px;">No active dishes are cooking in the kitchen right now.</td></tr>
                <% } else { %>
                    <% jobs.forEach((job, index) => { %>
                        <tr>
                            <td><b>#<%= index + 1 %></b></td>
                            <td><code style="color:#f1c40f;"><%= job.orderId || 'N/A' %></code></td>
                            <td style="color:#777;"><%= formatTime(job.createdAt) %></td>
                            <td><%= job.customerName || 'Anonymous' %> <span class="<%= job.priority === 1 ? 'badge-vip' : 'badge-std' %>"><%= job.priority === 1 ? 'VIP' : 'STD' %></span></td>
                            <td>
                                <%= job.quantity || 1 %>x <%= job.foodName || 'Food Item' %>
                                <br>
                                <small style="color: #2ecc71; font-weight: bold; font-size: 0.85rem;">
                                    ₦<%= (job.totalPrice || 0).toLocaleString() %>
                                </small>
                            </td>
                            <td><%= (job.processingTime || 0) * (job.quantity || 1) %> mins</td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>

        <!-- MODULE 4: DISPATCH DESK OVERVIEW -->
        <h3>
            <span>⏳ Counter Pickup Desk (Awaiting Collection Overview)</span>
            <span class="stat-count-badge orange-badge"><%= locals.pendingPickup ? pendingPickup.length : 0 %> Pending Pickup</span>
        </h3>
        <table>
            <thead>
                <tr>
                    <th>Verification ID</th>
                    <th>Ready Since</th>
                    <th>Customer Name</th>
                    <th>Food Item Details</th>
                    <th>Total Revenue Due</th>
                </tr>
            </thead>
            <tbody>
                <% if (locals.pendingPickup && pendingPickup.length > 0) { %>
                    <% pendingPickup.forEach(job => { %>
                        <tr style="background-color: #0e1a12;">
                            <td><code style="color:#2ecc71; font-size:14px; font-weight:bold;"><%= job.orderId %></code></td>
                            <td style="color:#888;"><%= formatTime(job.updatedAt) %></td>
                            <td><%= job.customerName %></td>
                            <td><%= job.quantity || 1 %>x <%= job.foodName %></td>
                            <td style="color: #2ecc71; font-weight: bold;">₦<%= (job.totalPrice || 0).toLocaleString() %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" style="text-align:center; color: #777; padding: 20px;">No processed meals are currently waiting at the dispatch desk.</td></tr>
                <% } %>
            </tbody>
        </table>

        <!-- MODULE 5: BUSINESS TRANSACTION LOG AUDIT TRACE -->
        <h3>
            <span>📜 Settled Transaction Ledgers (Historical Sales Archive)</span>
            <div style="display:flex; align-items:center; gap:12px;">
                <a href="/admin/archive" class="view-all-link">🔎 View Full Audit Logs</a>
                <span class="stat-count-badge green-badge"><%= locals.completedCount || 0 %> Finalized</span>
            </div>
        </h3>
        <table>
            <thead>
                <tr>
                    <th>Verification Token</th>
                    <th>Dispatched At</th>
                    <th>Customer Name</th>
                    <th>Dispatched Foods</th>
                    <th>Revenue Extracted</th>
                </tr>
            </thead>
            <tbody>
                <% if (!locals.history || history.length === 0) { %>
                    <tr><td colspan="5" style="text-align:center; color: #666; padding: 20px;">No business transactions archived for today yet.</td></tr>
                <% } else { %>
                    <% history.forEach(order => { %>
                        <tr style="background: rgba(255,255,255,0.01); color:#aaa;">
                            <td><code style="color:#2ecc71;"><%= order.orderId %></code></td>
                            <td style="color: #666; font-size:13px;"><%= formatTime(order.updatedAt) %></td>
                            <td><%= order.customerName %></td>
                            <td><%= order.quantity || 1 %>x <%= order.foodName %></td>
                            <td style="color:#2ecc71; font-weight:bold;">₦<%= (order.totalPrice || 0).toLocaleString() %></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- MODULE 6: SIDEBAR FINANCIAL ANALYTICS COCKPIT -->
    <div class="sidebar">
        <div style="background: rgba(52, 152, 219, 0.02); padding: 20px; border-radius: 12px; border: 1px solid var(--border-glow);">
            <h3 style="color:#5dade2; border:none; padding:0; margin-top:0; margin-bottom:15px; font-size:15px;">📊 Financial Statistics</h3>
            <p style="font-size:13px; color:var(--text-muted); margin-bottom:2px;">Gross Store Income:</p>
            <p style="font-size: 26px; font-weight: bold; color: var(--accent-green); margin-top:0; margin-bottom: 20px;">₦<%= locals.revenue ? revenue.toLocaleString() : '0' %></p>
            
            <p style="font-size:13px; color:var(--text-muted); margin-bottom:2px;">Dispatched Ticket Volume:</p>
            <p style="font-size: 20px; font-weight: bold; color: var(--accent-blue); margin-top:0; margin-bottom:0;"><%= locals.completedCount || 0 %> Plates Served</p>
        </div>
        
        <a href="/admin-logout" class="logout-btn">🔒 Secure Logout</a>
    </div>
</div>

<!-- LIVE WEBWORK BROADCAST LISTENERS -->
<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    socket.on('queueUpdate', (data) => {
        console.log("System update received:", data.message);
        window.location.reload();
    });
</script>
</body>
</html>