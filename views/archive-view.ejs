<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>OGITECH - Permanent Transaction Ledger</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color: #111; color: #fff; }
        .ledger-box { max-width: 1100px; margin: 0 auto; background: #222; padding: 30px; border-radius: 8px; border: 1px solid #333; }
        h2 { color: #2ecc71; border-bottom: 2px solid #2ecc71; padding-bottom: 10px; margin-top: 0; display: flex; justify-content: space-between; align-items: center; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #444; padding: 12px; text-align: left; }
        th { background-color: #333; color: #2ecc71; }
        tr:nth-child(even) { background-color: #1a1a1a; }
        .back-btn { padding: 10px 20px; background: #34495e; color: white; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 14px; }
        .back-btn:hover { background: #2c3e50; }
        .total-pill { background: #2ecc71; color: #111; padding: 4px 12px; border-radius: 20px; font-size: 14px; font-weight: bold; }
    </style>
</head>
<body>

<div class="ledger-box">
    <h2>
        <span>📜 Complete Historical Sales Archive (<%= role.toUpperCase() %> VIEW)</span>
        <span class="total-pill">Total Items: <%= history.length %></span>
    </h2>
    <p style="color:#aaa; margin-bottom: 25px;">This log indexes the permanent ledger sequence synced with MongoDB Cloud Pipelines.</p>

    <table>
        <thead>
            <tr>
                <th>Index</th>
                <th>Verification Token</th>
                <th>Dispatched Timestamp</th>
                <th>Customer Name</th>
                <th>Dispatched Items</th>
                <th>Revenue Confirmed</th>
            </tr>
        </thead>
        <tbody>
            <% if (history && history.length > 0) { %>
                <% history.forEach((order, idx) => { %>
                    <tr>
                        <td><b style="color:#666;">#<%= idx + 1 %></b></td>
                        <td><code style="color:#2ecc71; font-weight:bold;"><%= order.orderId %></code></td>
                        <td style="color:#aaa;"><%= formatTime(order.updatedAt) %></td>
                        <td><%= order.customerName %></td>
                        <td><%= order.quantity || 1 %>x <%= order.foodName %></td>
                        <td style="color:#2ecc71; font-weight:bold;">₦<%= (order.totalPrice || 0).toLocaleString() %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="6" style="text-align:center; color:#777; padding:20px;">No transaction history exists in the archive logs.</td></tr>
            <% } %>
        </tbody>
    </table>

    <div style="margin-top: 30px; display: flex; justify-content: flex-start;">
        <a href="/<%= role %>" class="back-btn">⬅ Back to Functional Operational Dashboard</a>
    </div>
</div>

</body>
</html>